# Next.js browser-side API base. Leave as /api so frontend requests hit the local Next rewrite first.
NEXT_PUBLIC_API_BASE_URL=/api

# Local NestJS backend origin. The frontend runs on 4000 and the backend usually runs on 3000.
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000

# Optional direct Socket.IO origin. Leave empty to fall back to NEXT_PUBLIC_BACKEND_URL.
NEXT_PUBLIC_SOCKET_BASE_URL=

# Optional server-only override for the Next rewrite target.
BACKEND_PROXY_TARGET=http://localhost:3000

# Enable browser-only demo mode for hosted previews like Vercel.
NEXT_PUBLIC_DEMO_MODE=false
